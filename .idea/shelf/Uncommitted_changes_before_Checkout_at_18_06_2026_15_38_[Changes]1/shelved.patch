+package de.jakomi1.voiceServer.utils;
+
+import de.jakomi1.voiceServer.Scheduler;
+import de.jakomi1.voiceServer.VoiceServer;
+import de.maxhenkel.voicechat.api.events.MicrophonePacketEvent;
+import de.maxhenkel.voicechat.api.opus.OpusDecoder;
+import org.bukkit.Bukkit;
+import org.bukkit.command.CommandSender;
+import org.bukkit.entity.Player;
+
+import java.io.*;
+import java.time.Instant;
+import java.util.*;
+import java.util.concurrent.ConcurrentHashMap;
+
+public class TranscriptUtils {
+
+    private static final int FRAME_SIZE = 960;
+    private static final int SILENCE_RMS_THRESHOLD = 850;
+    private static final long SILENCE_FLUSH_MS = 650L;
+    private static final long MIN_SEGMENT_MS = 900L;
+    private static final long MAX_SEGMENT_MS = 8000L;
+    private static final long CHECK_INTERVAL_TICKS = 4L;
+
+    private static final long PRE_ROLL_MS = 350L;
+    private static final int PRE_ROLL_MAX_BYTES =
+            (int) ((48000F * 2 * PRE_ROLL_MS) / 1000.0);
+
+    private static final Map<UUID, TranscriptSession> ACTIVE = new ConcurrentHashMap<>();
+
+    public static void start(Player target, int seconds, String modelName, CommandSender requester) {
+        if (target == null) {
+            MessageUtils.sendError(requester, "Spieler nicht gefunden.");
+            return;
+        }
+
+        if (seconds <= 0) {
+            MessageUtils.sendError(requester, "Seconds must be > 0.");
+            return;
+        }
+
+        if (!DataUtils.hasWhisperBackend(modelName)) {
+            MessageUtils.sendError(requester,
+                    "Whisper-Backend oder Modell fehlt. Modelle liegen in plugins/VoiceServer/whisper/models/");
+            return;
+        }
+
+        UUID uuid = target.getUniqueId();
+
+        if (ACTIVE.containsKey(uuid)) {
+            MessageUtils.sendError(requester, target.getName() + " wird bereits transkribiert.");
+            return;
+        }
+
+        TranscriptSession session = new TranscriptSession(uuid, target.getName(), requester, seconds, modelName);
+        ACTIVE.put(uuid, session);
+
+        MessageUtils.sendSuccess(requester,
+                "Transkript gestartet für " + target.getName() +
+                        " für " + seconds + " Sekunden. Modell: " + modelName);
+
+        if (target.isOnline()) {
+            MessageUtils.sendSuccess(target,
+                    "Für deine Stimme läuft jetzt ein sichtbares Transkript für " + seconds + " Sekunden.");
+        }
+
+        session.checkTask = Scheduler.runAsyncTimer(
+                () -> checkAndFlush(uuid),
+                CHECK_INTERVAL_TICKS,
+                CHECK_INTERVAL_TICKS
+        );
+
+        session.stopTask = Scheduler.runLater(
+                () -> stop(uuid, false),
+                seconds * 20L
+        );
+    }
+
+    public static void onMicrophonePacket(MicrophonePacketEvent event) {
+        if (event == null || event.getSenderConnection() == null || event.getPacket() == null) return;
+
+        UUID senderUuid = event.getSenderConnection().getPlayer().getUuid();
+        TranscriptSession session = ACTIVE.get(senderUuid);
+        if (session == null) return;
+
+        byte[] opus = event.getPacket().getOpusEncodedData();
+        if (opus == null || opus.length == 0) return;
+
+        try {
+            short[] pcm = session.decoder.decode(opus);
+            if (pcm == null || pcm.length == 0) return;
+
+            boolean speech = containsSpeech(pcm);
+            long now = System.currentTimeMillis();
+
+            synchronized (session.lock) {
+                if (session.closing) return;
+
+                if (!session.capturing) {
+                    session.addPreRoll(opus);
+
+                    if (!speech) return;
+
+                    session.capturing = true;
+                    session.segmentStartedAt = now;
+                    session.lastSpeechAt = now;
+                    session.hasSpeech = true;
+
+                    session.liveOpusPackets.addAll(session.drainPreRoll());
+                    return;
+                }
+
+                if (speech) {
+                    session.lastSpeechAt = now;
+                }
+
+                session.hasSpeech = session.hasSpeech || speech;
+                session.liveOpusPackets.add(opus.clone());
+            }
+
+        } catch (Exception e) {
+            e.printStackTrace();
+        }
+    }
+
+    public static void stop(UUID uuid, boolean silent) {
+        TranscriptSession session = ACTIVE.remove(uuid);
+        if (session == null) return;
+
+        try {
+            if (session.checkTask != null) session.checkTask.cancel();
+        } catch (Exception ignored) {}
+
+        try {
+            if (session.stopTask != null) session.stopTask.cancel();
+        } catch (Exception ignored) {}
+
+        List<byte[]> finalPackets;
+
+        synchronized (session.lock) {
+            session.closing = true;
+            finalPackets = session.swapLivePackets();
+            session.capturing = false;
+            session.hasSpeech = false;
+            session.segmentStartedAt = 0L;
+            session.lastSpeechAt = 0L;
+        }
+
+        enqueueChunk(session, finalPackets, true, silent);
+    }
+
+    private static void checkAndFlush(UUID uuid) {
+        TranscriptSession session = ACTIVE.get(uuid);
+        if (session == null) return;
+
+        long now = System.currentTimeMillis();
+        List<byte[]> toFlush = null;
+
+        synchronized (session.lock) {
+            if (session.closing || !session.capturing || !session.hasSpeech) return;
+
+            long sinceSpeech = now - session.lastSpeechAt;
+            long age = now - session.segmentStartedAt;
+
+            boolean pause = sinceSpeech >= SILENCE_FLUSH_MS && age >= MIN_SEGMENT_MS;
+            boolean max = age >= MAX_SEGMENT_MS;
+
+            if (pause || max) {
+                toFlush = session.swapLivePackets();
+                session.capturing = false;
+                session.hasSpeech = false;
+                session.segmentStartedAt = 0L;
+                session.lastSpeechAt = 0L;
+            }
+        }
+
+        if (toFlush != null && !toFlush.isEmpty()) {
+            enqueueChunk(session, toFlush, false, true);
+        }
+    }
+
+    private static void enqueueChunk(TranscriptSession session, List<byte[]> packets,
+                                     boolean finishAfterDrain, boolean silent) {
+
+        boolean startWorker = false;
+
+        synchronized (session.lock) {
+            if (packets != null && !packets.isEmpty()) {
+                session.pendingChunks.addLast(packets);
+            }
+
+            if (finishAfterDrain) {
+                session.finishAfterDrain = true;
+                session.finishSilent = silent;
+            }
+
+            if (!session.workerRunning) {
+                session.workerRunning = true;
+                startWorker = true;
+            }
+        }
+
+        if (startWorker) {
+            Scheduler.runAsync(() -> processQueue(session));
+        }
+    }
+
+    private static void processQueue(TranscriptSession session) {
+        while (true) {
+            List<byte[]> chunk;
+            boolean finish = false;
+            boolean silent = false;
+
+            synchronized (session.lock) {
+                chunk = session.pendingChunks.pollFirst();
+
+                if (chunk == null) {
+                    if (session.finishAfterDrain) {
+                        session.finishAfterDrain = false;
+                        silent = session.finishSilent;
+                        session.finishSilent = false;
+                        finish = true;
+                    } else {
+                        session.workerRunning = false;
+                        return;
+                    }
+                }
+            }
+
+            if (chunk != null) {
+                try {
+                    transcribeChunk(session, chunk);
+                } catch (Exception e) {
+                    e.printStackTrace();
+                }
+                continue;
+            }
+
+            if (finish) {
+                try {
+                    finishSession(session, silent);
+                } finally {
+                    synchronized (session.lock) {
+                        session.workerRunning = false;
+                    }
+                }
+                return;
+            }
+        }
+    }
+
+    private static void transcribeChunk(TranscriptSession session, List<byte[]> packets) throws Exception {
+        if (packets == null || packets.isEmpty()) return;
+
+        File opusFile = null;
+
+        try {
+            opusFile = writeTempOpus(session, packets);
+
+            File model = DataUtils.getWhisperModel(session.modelName);
+            String transcript = transcribe(opusFile, model);
+            transcript = normalizeTranscript(transcript);
+
+            if (!transcript.isBlank()) {
+                List<String> parts = packageTranscript(transcript, 180);
+
+                Scheduler.run(() -> {
+                    if (session.requester == null) return;
+                    for (String p : parts) {
+                        session.requester.sendMessage(
+                                "§7[VC-Transcript] §f" +
+                                        session.targetName + " › " + p
+                        );
+                    }
+                });
+            }
+
+        } finally {
+            if (opusFile != null && opusFile.exists()) {
+                opusFile.delete();
+            }
+        }
+    }
+
+    private static void finishSession(TranscriptSession session, boolean silent) {
+        try {
+            session.decoder.close();
+        } catch (Exception ignored) {}
+
+        if (!silent && session.requester != null) {
+            MessageUtils.sendSuccess(session.requester, "Transkript beendet: " + session.targetName);
+        }
+
+        Player target = Bukkit.getPlayer(session.targetUuid);
+        if (target != null && target.isOnline()) {
+            MessageUtils.sendSuccess(target, "Dein Transkript wurde beendet.");
+        }
+    }
+
+    private static File writeTempOpus(TranscriptSession session, List<byte[]> packets) throws Exception {
+        File folder = new File(VoiceServer.plugin.getDataFolder(), "transcript-temp");
+        if (!folder.exists() && !folder.mkdirs()) {
+            throw new IOException("Could not create temp folder");
+        }
+
+        String name = session.targetName + "-" + Instant.now().toEpochMilli() + ".opus";
+        File file = new File(folder, sanitizeFileName(name));
+
+        OpusFileUtils.writeOggOpus(file, packets);
+        return file;
+    }
+
+    private static String transcribe(File opusFile, File model) throws Exception {
+        File exe = DataUtils.getWhisperExecutable();
+
+        if (!exe.exists()) return "[Whisper executable fehlt]";
+        if (model == null || !model.exists()) return "[Whisper model fehlt]";
+
+        String outBase = opusFile.getAbsolutePath().replaceFirst("\\.opus$", "");
+
+        List<String> cmd = new ArrayList<>();
+        cmd.add(exe.getAbsolutePath());
+        cmd.add("-m");
+        cmd.add(model.getAbsolutePath());
+        cmd.add("-f");
+        cmd.add(opusFile.getAbsolutePath());
+        cmd.add("-l");
+        cmd.add("de");
+        cmd.add("-otxt");
+        cmd.add("-of");
+        cmd.add(outBase);
+
+        ProcessBuilder pb = new ProcessBuilder(cmd);
+        pb.redirectErrorStream(true);
+
+        Process p = pb.start();
+
+        ByteArrayOutputStream log = new ByteArrayOutputStream();
+        try (InputStream is = p.getInputStream()) {
+            byte[] buf = new byte[4096];
+            int r;
+            while ((r = is.read(buf)) != -1) {
+                log.write(buf, 0, r);
+            }
+        }
+
+        int exit = p.waitFor();
+
+        File txt = new File(outBase + ".txt");
+        if (txt.exists()) {
+            String t = java.nio.file.Files.readString(txt.toPath()).trim();
+            txt.delete();
+            return t;
+        }
+
+        String stdout = log.toString().trim();
+        if (!stdout.isBlank()) return stdout;
+
+        return exit == 0 ? "" : "[STT Fehler: " + exit + "]";
+    }
+
+    private static boolean containsSpeech(short[] pcm) {
+        if (pcm == null || pcm.length == 0) return false;
+
+        int frames = Math.max(1, pcm.length / FRAME_SIZE);
+
+        for (int f = 0; f < frames; f++) {
+            int start = f * FRAME_SIZE;
+            int end = Math.min(pcm.length, start + FRAME_SIZE);
+
+            long sum = 0;
+            int n = 0;
+
+            for (int i = start; i < end; i++) {
+                sum += (long) pcm[i] * pcm[i];
+                n++;
+            }
+
+            if (n == 0) continue;
+
+            double rms = Math.sqrt(sum / (double) n);
+            if (rms >= SILENCE_RMS_THRESHOLD) return true;
+        }
+
+        return false;
+    }
+
+    private static List<String> packageTranscript(String text, int maxLen) {
+        List<String> out = new ArrayList<>();
+        if (text == null || text.isBlank()) return out;
+
+        String norm = normalizeTranscript(text);
+        String[] sentences = norm.split("(?<=[.!?])\\s+");
+
+        for (String s : sentences) {
+            s = s.trim();
+            if (s.isBlank()) continue;
+
+            if (s.length() <= maxLen) out.add(s);
+            else out.addAll(splitByWords(s, maxLen));
+        }
+
+        if (out.isEmpty()) out.addAll(splitByWords(norm, maxLen));
+        return out;
+    }
+
+    private static List<String> splitByWords(String text, int maxLen) {
+        List<String> out = new ArrayList<>();
+        String[] words = text.split("\\s+");
+
+        StringBuilder sb = new StringBuilder();
+
+        for (String w : words) {
+            if (sb.length() == 0) {
+                sb.append(w);
+            } else if (sb.length() + 1 + w.length() <= maxLen) {
+                sb.append(' ').append(w);
+            } else {
+                out.add(sb.toString());
+                sb.setLength(0);
+                sb.append(w);
+            }
+        }
+
+        if (sb.length() > 0) out.add(sb.toString());
+        return out;
+    }
+
+    private static String normalizeTranscript(String t) {
+        if (t == null) return "";
+        return t.replace("\r", " ")
+                .replace("\n", " ")
+                .replaceAll("\\s+", " ")
+                .trim();
+    }
+
+    private static String sanitizeFileName(String s) {
+        if (s == null) return "transcript.opus";
+        return s.replaceAll("[\\\\/:*?\"<>|]", "_");
+    }
+
+    private static class TranscriptSession {
+        final UUID targetUuid;
+        final String targetName;
+        final CommandSender requester;
+        final int seconds;
+        final OpusDecoder decoder;
+        final String modelName;
+
+        final Deque<byte[]> preRollPackets = new ArrayDeque<>();
+        final List<byte[]> liveOpusPackets = new ArrayList<>();
+        final Deque<List<byte[]>> pendingChunks = new ArrayDeque<>();
+        final Object lock = new Object();
+
+        volatile boolean capturing = false;
+        volatile boolean hasSpeech = false;
+        volatile boolean closing = false;
+
+        volatile boolean workerRunning = false;
+        volatile boolean finishAfterDrain = false;
+        volatile boolean finishSilent = false;
+
+        volatile long segmentStartedAt = 0L;
+        volatile long lastSpeechAt = 0L;
+
+        Scheduler.Task checkTask;
+        Scheduler.Task stopTask;
+
+        TranscriptSession(UUID targetUuid, String targetName, CommandSender requester, int seconds, String modelName) {
+            this.targetUuid = targetUuid;
+            this.targetName = targetName;
+            this.requester = requester;
+            this.seconds = seconds;
+            this.modelName = modelName;
+            this.decoder = VoiceServer.serverApi.createDecoder();
+        }
+
+        void addPreRoll(byte[] data) {
+            if (data == null || data.length == 0) return;
+
+            preRollPackets.addLast(data.clone());
+
+            int total = 0;
+            for (byte[] b : preRollPackets) total += b.length;
+
+            while (total > PRE_ROLL_MAX_BYTES && !preRollPackets.isEmpty()) {
+                byte[] removed = preRollPackets.removeFirst();
+                total -= removed.length;
+            }
+        }
+
+        List<byte[]> drainPreRoll() {
+            List<byte[]> out = new ArrayList<>(preRollPackets.size());
+            while (!preRollPackets.isEmpty()) {
+                out.add(preRollPackets.removeFirst());
+            }
+            return out;
+        }
+
+        List<byte[]> swapLivePackets() {
+            List<byte[]> out = new ArrayList<>(liveOpusPackets);
+            liveOpusPackets.clear();
+            return out;
+        }
+    }
+}
